# Copiez ce fichier en ".env.local" puis remplacez les valeurs.
# (Supabase > votre projet > Project Settings > API)

# "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# La clé publique de votre projet.
# Selon l'écran, elle s'appelle "anon public" OU "Publishable key".
NEXT_PUBLIC_SUPABASE_ANON_KEY=collez_votre_cle_ici
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=collez_votre_cle_ici

# --- Serveur uniquement (NE PAS préfixer par NEXT_PUBLIC) ---

# Clé SECRÈTE Supabase (Project Settings > API > "Secret keys" ou "service_role").
# Contourne la RLS : à garder privée.
SUPABASE_SERVICE_ROLE_KEY=collez_votre_cle_secrete_ici

# --- Notifications push (Web Push, gratuit) ---
# Générez une paire de clés VAPID une seule fois :
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=votre_cle_publique_vapid
VAPID_PRIVATE_KEY=votre_cle_privee_vapid
VAPID_SUBJECT=mailto:vous@exemple.fr
